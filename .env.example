# ============================================================================
# AI Evaluation Framework — BYOK (Bring Your Own Key)
# Copy this file to .env and fill in your values
# ============================================================================

# Mode: demo | live
EVAL_MODE=demo

# Default role to evaluate (override with --role CLI flag)
EVAL_ROLE=clinical_data_engineer

# System prompt source:
#   "local"           — use prompt from prompts/ in this codebase (default)
#   "none"            — send NO system prompt; test the deployed model's own prompt
#   "file:/path.txt"  — load system prompt from an external file
TARGET_SYSTEM_PROMPT=local

# ============================================================================
# TARGET MODEL — the model being evaluated
# ============================================================================
# Provider: openai | anthropic | azure | azure_assistant | azure_foundry | google | ollama
TARGET_PROVIDER=openai
TARGET_API_KEY=
TARGET_MODEL=gpt-4o
TARGET_BASE_URL=                    # Optional: override endpoint
TARGET_API_VERSION=2024-06-01       # Azure only
TARGET_DEPLOYMENT=                  # Azure: deployment name if different from model

# ============================================================================
# JUDGE MODEL — scores responses (optional, falls back to target)
# Tip: Use a strong model as judge even when testing weaker models
# ============================================================================
JUDGE_PROVIDER=                     # Falls back to TARGET_PROVIDER
JUDGE_API_KEY=                      # Falls back to TARGET_API_KEY
JUDGE_MODEL=                        # Falls back to TARGET_MODEL
JUDGE_BASE_URL=
JUDGE_API_VERSION=
JUDGE_DEPLOYMENT=

# ============================================================================
# PROVIDER EXAMPLES (uncomment the one you need)
# ============================================================================

# --- OpenAI ---
# TARGET_PROVIDER=openai
# TARGET_API_KEY=sk-...
# TARGET_MODEL=gpt-4o

# --- Anthropic / Claude ---
# TARGET_PROVIDER=anthropic
# TARGET_API_KEY=sk-ant-...
# TARGET_MODEL=claude-sonnet-4-20250514

# --- Azure OpenAI ---
# TARGET_PROVIDER=azure
# TARGET_API_KEY=your-azure-key
# TARGET_MODEL=gpt-4o
# TARGET_BASE_URL=https://your-resource.openai.azure.com
# TARGET_DEPLOYMENT=gpt-4o

# --- Azure AI Foundry (any model: GPT, Llama, Mistral, Phi, etc.) ---
# TARGET_PROVIDER=azure_foundry
# TARGET_API_KEY=your-foundry-key
# TARGET_MODEL=Llama-3.1-70B
# TARGET_BASE_URL=https://your-resource.openai.azure.com

# --- Google Gemini ---
# TARGET_PROVIDER=google
# TARGET_API_KEY=your-google-key
# TARGET_MODEL=gemini-2.0-flash

# --- Ollama (local) ---
# TARGET_PROVIDER=ollama
# TARGET_MODEL=llama3.1
# TARGET_BASE_URL=http://localhost:11434/v1

# ============================================================================
# MIXED EXAMPLE: Test Llama on Foundry, judge with GPT-4o on Azure
# ============================================================================
# TARGET_PROVIDER=azure_foundry
# TARGET_MODEL=Llama-3.1-70B
# TARGET_BASE_URL=https://your-resource.openai.azure.com
# TARGET_API_KEY=your-key
#
# JUDGE_PROVIDER=azure
# JUDGE_MODEL=gpt-4o
# JUDGE_BASE_URL=https://your-resource.openai.azure.com
# JUDGE_API_KEY=your-key
# JUDGE_DEPLOYMENT=gpt-4o
